# --- AI provider switch (server-side only; used by api/plan.ts) ---------------
# Pick the default provider. Options: openrouter (free) | perplexity | anthropic.
# Can also be overridden per-request via a `provider` field in the POST body.
PLAN_PROVIDER=openrouter

# OpenRouter — the free default. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Optional: override the model (default is a free one).
OPENROUTER_MODEL=tencent/hy3:free

# Perplexity (Sonar) — great for live, sourced research. https://docs.perplexity.ai
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_MODEL=sonar-pro

# Anthropic (Claude) — warmest tone, most reliable structured output.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# --- Frontend build flag ------------------------------------------------------
# Set to "false" to call the live /api/plan endpoint. Omit (or any other value)
# to keep the app fully seeded and offline-safe.
VITE_DEMO_MODE=false
